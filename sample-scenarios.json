{
  "lessonTitle": "第1回 Linux基本操作",
  "scenarios": [
    {
      "label": "SSHログイン",
      "allowed": ["ssh", "help", "clear"],
      "tasks": [
        {
          "text": "ssh student@linux-practice を実行する",
          "command": "ssh student@linux-practice",
          "expect": { "pendingHostKeyConfirmation": true }
        },
        {
          "text": "yes と入力して接続を続ける",
          "command": "yes",
          "expect": { "pendingPassword": true }
        },
        {
          "text": "パスワード linux を入力する",
          "command": "linux",
          "expect": { "loggedIn": true, "user": "student", "host": "linux-practice" }
        },
        {
          "text": "ログイン後のプロンプトを確認する",
          "command": "linux",
          "expect": { "loggedIn": true, "cwd": "/home/student" }
        }
      ]
    },
    {
      "label": "パス操作",
      "allowed": ["pwd", "ls", "cd", "cat", "help", "clear", "whoami", "exit"],
      "tasks": [
        {
          "text": "pwd で現在地を確認する",
          "command": "pwd",
          "expect": { "cwd": "/home/student" }
        },
        {
          "text": "cd documents で documents ディレクトリへ移動する",
          "command": "cd documents",
          "expect": { "cwd": "/home/student/documents" }
        },
        {
          "text": "ls でファイル一覧を見る",
          "command": "ls",
          "expect": { "exists": "/home/student/documents", "type": "dir" }
        },
        {
          "text": "cat lesson.txt で lesson.txt の内容を確認する",
          "command": "cat lesson.txt",
          "expect": { "file": "/home/student/documents/lesson.txt" }
        }
      ]
    },
    {
      "label": "作成と確認",
      "allowed": ["pwd", "ls", "cd", "cat", "mkdir", "touch", "echo", "help", "clear", "whoami", "exit"],
      "tasks": [
        {
          "text": "mkdir practice で practice ディレクトリを作る",
          "command": "mkdir practice",
          "expect": { "exists": "/home/student/practice", "type": "dir" }
        },
        {
          "text": "touch practice/report.txt で report.txt を作る",
          "command": "touch practice/report.txt",
          "expect": { "exists": "/home/student/practice/report.txt", "type": "file" }
        },
        {
          "text": "echo done > practice/report.txt で文字を書き込む",
          "command": "echo done > practice/report.txt",
          "expect": { "file": "/home/student/practice/report.txt", "content": "done\n" }
        },
        {
          "text": "cat practice/report.txt で内容を確認する",
          "command": "cat practice/report.txt",
          "expect": { "file": "/home/student/practice/report.txt", "content": "done\n" }
        }
      ]
    }
  ]
}
